rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    // Tasks are private to their creator. Users must be authenticated and
    // may only create/read/update/delete documents they own. Prep subcollections
    // inherit the same per-task ownership rule.
    match /tasks/{taskId} {
      // Create: authenticated and request.ownerId must match caller
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;

      // Read / update / delete: only the owner may access the task.
      allow read, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid
        // Prevent changing ownerId on updates
        && (request.method != 'update' || request.resource.data.ownerId == resource.data.ownerId);

      // Prep items under a task: allowed only to the task owner.
      match /prep/{itemId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/tasks/$(taskId)).data.ownerId == request.auth.uid;
      }
    }

    // Deny all other accesses by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}