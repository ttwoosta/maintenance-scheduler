rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Prep photos live under prep-photos/{taskId}/{itemId}/{file}.
    // NOTE: this starter rule is time-boxed — replace it with an auth/ownership
    // rule (mirroring firestore.rules) before the expiry date below.
    match /{allPaths=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 19);
    }
  }
}
